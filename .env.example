# Frontend
VITE_WS_URL=wss://your-ws-host.example.com/ws

# Server
PORT=8080
CLIENT_ORIGIN=https://your-vercel-app.vercel.app
# Supabase direct (may require IPv6 on your host network):
# DATABASE_URL=postgresql://postgres:password@db.<project-ref>.supabase.co:5432/postgres
# Supabase pooler (works on IPv4-only networks):
# DATABASE_URL=postgresql://postgres.<project-ref>:password@aws-1-us-east-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres
# Optional override. Defaults are inferred:
# - false for Supabase pooler
# - true for Supabase direct hosts
# DATABASE_SSL_REJECT_UNAUTHORIZED=false
ROOM_TTL_HOURS=24
